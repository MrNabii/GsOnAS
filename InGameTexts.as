    g_strmsg[1]="Уровни персонажей\r\n\r\n Лимиты по уровням, в зависимости от волн. Нельзя Повысить больше, чем данный лимит. \r\n\r\n";
    g_strmsg[1]=g_strmsg[1] + "Уровнни скиллов. У первых 10 боссов есть квесты, выполняя которые можно получать скилл пойнты, используемые для прокачки. \r\n\r\n";
