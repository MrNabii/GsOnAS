int GetGlibaPlacePointCount() {
    return int(GLIBA_POINTS_X.length());
}

void GetGlibaPlacePoint(int index, float &out x, float &out y) {
    int n = int(GLIBA_POINTS_X.length());
    if (n <= 0) { x = 0.0; y = 0.0; return; }
    if (index < 0) index = 0;
    if (index >= n) index = n - 1;
    x = GLIBA_POINTS_X[index];
    y = GLIBA_POINTS_Y[index];
}

void GetRandomGlibaPlacePoint(float &out x, float &out y) {
    int n = int(GLIBA_POINTS_X.length());
    if (n <= 0) { x = 0.0; y = 0.0; return; }
    int idx = Jass::GetRandomInt(0, n - 1);
    Jass::ConsolePrint("\nRandom Gliba point index: " + idx);
    x = GLIBA_POINTS_X[idx];
    y = GLIBA_POINTS_Y[idx];
}

float GetRandomGlibaPlaceX(int idx) {
    int n = int(GLIBA_POINTS_X.length());
    if (n <= 0) return 0.0;
    if (idx < 0) idx = 0;
    if (idx >= n) idx = n - 1;
    return GLIBA_POINTS_X[idx];
}

float GetRandomGlibaPlaceY(int idx) {
    int n = int(GLIBA_POINTS_Y.length());
    if (n <= 0) return 0.0;
    if (idx < 0) idx = 0;
    if (idx >= n) idx = n - 1;
    return GLIBA_POINTS_Y[idx];
}
